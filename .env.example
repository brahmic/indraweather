NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Required by Docker Compose. Generate with: openssl rand -hex 32
POSTGRES_DB=indra
POSTGRES_USER=indra
POSTGRES_PASSWORD=replace-with-a-long-random-password

# For running the app directly outside Docker instead of the fields above:
# DATABASE_URL=postgres://indra:password@localhost:5432/indra

# Create a bot with @BotFather. Leave empty to run collectors and HTTP only.
TELEGRAM_BOT_TOKEN=

# MAX production webhook. The API endpoint is fixed in code.
MAX_BOT_TOKEN=
MAX_PUBLIC_BASE_URL=

# Free for non-commercial use: https://dashboard.stormglass.io/register
STORMGLASS_API_KEY=

# Optional Sentinel-1 radar command. Create an OAuth Client (Client Credentials)
# in Copernicus Data Space and keep both values secret.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Optional Lightning Imager observations from EUMETSAT Data Store.
# Use the permanent Consumer Key and Consumer Secret, not a short-lived API Token.
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=
# Lightning observations are requested on demand. The data cache does not retain
# any credentials and is limited to the current map viewport.
LIGHTNING_WINDOW_MINUTES=30
LIGHTNING_CACHE_MINUTES=5
LIGHTNING_MAX_PRODUCT_BYTES=60000000
COPERNICUS_RADAR_LOOKBACK_DAYS=14
RADAR_CACHE_MINUTES=30

APP_TIMEZONE=Europe/Moscow
SCHEDULE_TIMES=05:00,11:00,17:00,23:00
SCHEDULE_RETRY_MINUTES=15
# On startup, recover the last missed scheduled slot if it is no older than this.
SCHEDULE_RECOVERY_HOURS=8
FRESH_FORECAST_MINUTES=60
# Failed recipient deliveries are retried from PostgreSQL with exponential backoff.
DELIVERY_RETRY_INTERVAL_SECONDS=30
DELIVERY_RETRY_MAX_ATTEMPTS=5
# Raw hourly forecasts from completed runs are retained for this many days.
FORECAST_DATA_RETENTION_DAYS=90
# Hidden /update command: optional comma-separated IDs allowed to force a new bulletin.
# If a channel list is empty, its first /update sender becomes the stored owner.
# It is not shown in bot command menus or /help.
UPDATE_TELEGRAM_RECIPIENT_IDS=
UPDATE_MAX_RECIPIENT_IDS=
WEATHER_TIMEOUT_MS=15000
WEATHER_RETRY_COUNT=2

# EUMETSAT EUMETView WMS; no API key is required.
SATELLITE_ENABLED=true
SATELLITE_WMS_URL=https://view.eumetsat.int/geoserver/wms
SATELLITE_WFS_URL=https://view.eumetsat.int/geoserver/wfs
SATELLITE_BBOX=30,64,36,68
SATELLITE_WIDTH=1000
SATELLITE_HEIGHT=800
SATELLITE_MAX_AGE_MINUTES=90
SATELLITE_CACHE_MINUTES=10
# Bound RAM used by per-viewport satellite, diagnostic, and radar image caches.
IMAGE_CACHE_MAX_ENTRIES=16
SATELLITE_MAX_IMAGE_BYTES=9000000

# Rolling 12-hour cloud-motion animation. It samples the infrared layer every
# 20 minutes, stores frames in the Docker volume, and sends a compact MP4.
SATELLITE_ANIMATION_ENABLED=true
SATELLITE_ANIMATION_INTERVAL_MINUTES=20
SATELLITE_ANIMATION_WINDOW_HOURS=12
SATELLITE_ANIMATION_RETENTION_HOURS=26
SATELLITE_ANIMATION_MIN_FRAMES=3
SATELLITE_ANIMATION_DIRECTORY=/var/lib/indra/satellite-animation
SATELLITE_ANIMATION_MAX_BYTES=15000000

# Separate rolling diagnostic animation sent by /animation. It uses the same timing
# as the infrared animation, but never mixes daytime cloud types with nighttime fog.
CLOUD_ANIMATION_ENABLED=true
CLOUD_ANIMATION_DIRECTORY=/var/lib/indra/cloud-animation
CLOUD_DIAGNOSTIC_CACHE_MINUTES=10

# Per-user map animations are queued only after /animation for a
# saved custom /map viewport. Changing the map itself sends nothing.
PERSONAL_ANIMATION_ENABLED=true
PERSONAL_ANIMATION_DIRECTORY=/var/lib/indra/personal-animation
PERSONAL_ANIMATION_CACHE_MINUTES=20

# Detailed Sentinel-3 OLCI image of Kandalaksha Bay. No API key is required.
DETAILED_SATELLITE_ENABLED=true
DETAILED_SATELLITE_BBOX=31.4,65.6,35.8,67.4
DETAILED_SATELLITE_WIDTH=1000
DETAILED_SATELLITE_HEIGHT=1000
DETAILED_SATELLITE_MAX_AGE_HOURS=12
# A partial frame is still shown from 20%; the bulletin states the gap and the
# predicted next pass whenever coverage is below the preferred 70%.
DETAILED_SATELLITE_MIN_COVERAGE_PERCENT=20
DETAILED_SATELLITE_PREFERRED_COVERAGE_PERCENT=70
DETAILED_SATELLITE_CACHE_MINUTES=30
DETAILED_SATELLITE_PASS_RADIUS_KM=450
EUMETSAT_CATALOG_URL=https://api.eumetsat.int/data/search-products/1.0.0/os
EUMETSAT_SENTINEL_COLLECTION_ID=EO:EUM:DAT:0409
EUMETSAT_TLE_S3A_URL=https://service.eumetsat.int/tle/javascript/data_content_s3a.js
EUMETSAT_TLE_S3B_URL=https://service.eumetsat.int/tle/javascript/data_content_s3b.js

WIND_CHANGE_THRESHOLD_MS=2
WIND_AGREEMENT_THRESHOLD_MS=2
GUST_AGREEMENT_THRESHOLD_MS=3
DIRECTION_CHANGE_THRESHOLD_DEG=45
DIRECTION_AGREEMENT_THRESHOLD_DEG=45
EVENT_TIME_AGREEMENT_HOURS=2
