{
  "name": "kandalaksha-weather-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.2",
    "grammy": "^1.44.0",
    "h5wasm": "^0.10.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "satellite.js": "^7.0.1",
    "sharp": "^0.35.3",
    "suncalc": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/suncalc": "^1.9.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
